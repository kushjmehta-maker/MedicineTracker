# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/medicine_tracker

# ─── Firebase Admin ───────────────────────────────────────────────────────────
# Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Paste the private key with literal \n separators (Railway handles the escaping)
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----\n"

# ─── Billing ──────────────────────────────────────────────────────────────────
# Google Play service account key JSON (for server-side receipt validation)
PLAY_STORE_SERVICE_ACCOUNT_KEY={}
# Apple App Store shared secret (for server-side receipt validation)
APP_STORE_SHARED_SECRET=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for dev
ALLOWED_ORIGINS=*

# ─── Cache TTL ────────────────────────────────────────────────────────────────
USER_PLAN_TTL_MS=600000

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── Logging ──────────────────────────────────────────────────────────────────
# "development" → pretty-printed pino output
# "production"  → JSON pino output
LOG_LEVEL=info

# ─── Adherence Computation ────────────────────────────────────────────────────
# Cron schedule for nightly batch (default: 2 AM UTC)
ADHERENCE_CRON_SCHEDULE=0 2 * * *

# Users processed per DB batch (tune based on available memory)
ADHERENCE_BATCH_SIZE=1000

# ─── Strategy Cache ───────────────────────────────────────────────────────────
# How long the mobile client should cache the strategy response (seconds)
STRATEGY_CACHE_TTL_SECONDS=86400

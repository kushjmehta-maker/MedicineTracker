{
  "name": "medicine-tracker-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node --watch src/server.ts",
    "build": "tsc --outDir dist",
    "start": "node dist/server.js",
    "migrate": "ts-node src/db/migrate.ts",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "ts:check": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "fastify": "^4.26.2",
    "firebase-admin": "^12.0.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.1.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  }
}
